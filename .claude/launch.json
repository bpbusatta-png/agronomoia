    {
      "name": "mobile-app-campo",
      "runtimeExecutable": "C:\\Program Files\\nodejs\\node.exe",
      "runtimeArgs": ["mobile/app-campo/node_modules/expo/bin/cli", "start", "mobile/app-campo", "--web", "--localhost"],
      "port": 8081
