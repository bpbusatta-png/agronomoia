      "runtimeExecutable": "backend/.venv/Scripts/uvicorn.exe",
      "runtimeArgs": ["main:app", "--reload", "--app-dir", "backend", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "frontend-dashboard",
      "runtimeExecutable": "C:\\Program Files\\nodejs\\node.exe",
      "runtimeArgs": ["frontend/dashboard/node_modules/vite/bin/vite.js", "frontend/dashboard", "--port", "5173"],
      "port": 5173
