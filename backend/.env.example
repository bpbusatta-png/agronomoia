DATABASE_URL=postgresql+psycopg2://agronomo:agronomo@localhost:5432/agronomo_ia
# Gerar com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-este-valor-por-um-hex-aleatorio

# Armazenamento de arquivos (fotos) -- MinIO local por padrão, compatível com S3
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=agronomo-ia
STORAGE_PUBLIC_URL=http://localhost:9000/agronomo-ia

# Reconhecimento por IA (pragas/doencas/plantas daninhas/plantas atipicas) --
# usa a API do Google Gemini (tem cota gratuita) para classificar fotos. Gere
# sua chave em https://aistudio.google.com/apikey . Sem essa chave, POST
# /api/reconhecimento/classificar responde 503 -- o resto do sistema funciona normalmente.
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.0-flash
